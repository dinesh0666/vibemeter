{
  "name": "vibemeter",
  "displayName": "VibeMeter",
  "description": "Elevate your vibe coding — real-time flow state tracker, achievement hype machine, and AI coach.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibemeter.dashboard",
        "title": "VibeMeter: Open Vibe Dashboard"
      },
      {
        "command": "vibemeter.coach",
        "title": "VibeMeter: AI Vibe Coach"
      },
      {
        "command": "vibemeter.vibecheck",
        "title": "VibeMeter: Quick Vibe Check"
      }
    ],
    "configuration": {
      "title": "VibeMeter",
      "properties": {
        "vibemeter.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your [Google Gemini API key](https://aistudio.google.com/apikey). Used to power the AI Vibe Coach.",
          "order": 1
        }
      }
    },
    "keybindings": [
      {
        "command": "vibemeter.dashboard",
        "key": "ctrl+alt+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "vibemeter.coach",
        "key": "ctrl+alt+c",
        "mac": "cmd+shift+c"
      },
      {
        "command": "vibemeter.vibecheck",
        "key": "ctrl+alt+v",
        "mac": "cmd+shift+k"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
